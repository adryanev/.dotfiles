.env-install
.DS_Store

# Override global ~/.gitignore_global's `/.config` rule
# (a Ruby-project convention that bans this directory). Dotfiles
# tracks selective contents of .config/ -- specific subdirs still
# ignored below.
!/.config

.config/raycast/

# GPG/PGP Keys - NEVER commit these
gnupg/*.key
gnupg/*.asc
gnupg/*.gpg
gnupg/private-keys-v1.d/
gnupg/openpgp-revocs.d/
gnupg/pubring.kbx
gnupg/pubring.kbx~
gnupg/trustdb.gpg
gnupg/random_seed
gnupg/.#*
gnupg/S.gpg-agent*
gnupg/S.scdaemon
gnupg/S.dirmngr

# Cloned skill repos (managed by sync-agent-skills.sh)
.claude/sources/

# Local agent configs with secrets or machine-specific state
.config/opencode/config.json

# safe_symlink backups from scripts/lib/common.sh
*.backup.[0-9]*

# claude-mem runtime state (ChromaDB + logs, per-machine, large)
.claude-mem/

# Cursor runtime state adjacent to stowed configs
.cursor/chats/
.cursor/projects/
.cursor/prompt_history.json
.cursor/statsig-cache.json
.cursor/ai-tracking/
