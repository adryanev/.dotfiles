{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion": 1,

  // This file uses JSON with comments (JSONC).
  // Uncomment and edit any setting to make it file-managed.
  // Remove a setting to fall back to the value saved in Settings.
  // cmux creates this template on launch when ~/.config/cmux/cmux.json is missing.
  // Legacy settings.json files are read only as fallback for keys not present here.

     "app" : {
       "openSupportedFilesInCmux" : true,
       "preferredEditor" : "zed",
       "reorderOnNotification" : true,
       "minimalMode" : false,
       "hideTabCloseButton" : false,
       "warnBeforeClosingTabXButton" : false,
       "renameSelectsExistingName" : true,
       "appearance" : "system",
       "commandPaletteSearchesAllSurfaces" : false,
       "sendAnonymousTelemetry" : true,
       "language" : "system",
       "forkConversationDefaultDestination" : "right",
       "confirmQuit" : "always",
       "windowTitleTemplate" : "",
       "focusPaneOnFirstClick" : false,
       "appIcon" : "automatic",
       "newWorkspacePlacement" : "afterCurrent",
       "workspaceInheritWorkingDirectory" : true,
       "keepWorkspaceOpenWhenClosingLastSurface" : false,
       "menuBarOnly" : false,
       "openMarkdownInCmuxViewer" : true,
       "warnBeforeClosingTab" : true,
       "iMessageMode" : false
     },

     "workspaceGroups" : {
       "newWorkspacePlacement" : "afterCurrent"
     },

     "terminal" : {
       "scrollSpeed" : 1,
       "showTextBoxOnNewTerminals" : false,
       "textBoxMaxLines" : 10,
       "autoResumeAgentSessions" : true,
       "focusTextBoxOnNewTerminals" : false,
       "copyOnSelect" : false,
       "rendererRealization" : {
         "idleSeconds" : 30,
         "enabled" : true,
         "maxWarmRenderers" : 12
       },
       "agentHibernation" : {
         "maxLiveTerminals" : 12,
         "enabled" : false,
         "idleSeconds" : 5
       },
       "textBoxDefaultSubmitAction" : "text-entry",
       "resumeCommands" : [

       ],
       "showScrollBar" : true,
       "textBoxSubmitActions" : [
         {
           "title" : "Claude Dangerous",
           "systemImage" : "sparkle",
           "kind" : "commandTemplate",
           "backgroundColorHex" : "#F6D5C8",
           "commandTemplate" : "claude --dangerously-skip-permissions -- {{prompt}}",
           "id" : "claude",
           "assetName" : "AgentIcons\/Claude"
         },
         {
           "assetName" : "AgentIcons\/Codex",
           "kind" : "commandTemplate",
           "title" : "Codex --yolo",
           "systemImage" : "sparkles",
           "backgroundColorHex" : "#8FDBFF",
           "id" : "codex",
           "commandTemplate" : "codex --yolo -- {{prompt}}"
         },
         {
           "commandTemplate" : "opencode --prompt {{prompt}}",
           "systemImage" : "curlybraces",
           "title" : "OpenCode",
           "kind" : "commandTemplate",
           "id" : "opencode",
           "backgroundColorHex" : "#B5E48C",
           "assetName" : "AgentIcons\/OpenCode"
         },
         {
           "id" : "pi",
           "kind" : "commandTemplate",
           "backgroundColorHex" : "#D0B3FF",
           "assetName" : "AgentIcons\/Pi",
           "commandTemplate" : "pi -- {{prompt}}",
           "title" : "Pi",
           "systemImage" : "brain.head.profile"
         }
       ]
     },

     "notifications" : {
       "dockBadge" : true,
       "hooks" : [

       ],
       "paneFlash" : true,
       "showInMenuBar" : true,
       "sound" : "default",
       "hooksMode" : "append",
       "customSoundFilePath" : "",
       "command" : "",
       "unreadPaneRing" : true
     },

     "sidebar" : {
       "pathLastSegmentOnly" : false,
       "openPortLinksInCmuxBrowser" : true,
       "showNotificationMessage" : true,
       "showPorts" : true,
       "wrapWorkspaceTitles" : false,
       "notificationMessageLineLimit" : 12,
       "showCustomMetadata" : true,
       "showAgentActivity" : true,
       "hideAllDetails" : false,
       "showLog" : true,
       "showPullRequests" : true,
       "beta" : {
         "workspaceTodos" : {
           "checklistStyle" : "popover"
         }
       },
       "stackBranchDirectory" : false,
       "openPullRequestLinksInCmuxBrowser" : true,
       "showSSH" : true,
       "showWorkspaceDescription" : true,
       "watchGitStatus" : true,
       "showProgress" : true,
       "showBranchDirectory" : true,
       "branchLayout" : "vertical",
       "makePullRequestsClickable" : true
     },

     "workspaceColors" : {
       "colors" : {
         "Navy" : "#1A5276",
         "Magenta" : "#AD1457",
         "Purple" : "#6A1B9A",
         "Charcoal" : "#3E4B5E",
         "Green" : "#196F3D",
         "Teal" : "#006B6B",
         "Indigo" : "#283593",
         "Red" : "#C0392B",
         "Brown" : "#7B3F00",
         "Amber" : "#7D6608",
         "Aqua" : "#0E6B8C",
         "Crimson" : "#922B21",
