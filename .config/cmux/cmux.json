     "sidebarAppearance" : {
       "tintOpacity" : 0.17999999999999999,
       "tintColor" : "#000000",
       "lightModeTintColor" : null,
       "darkModeTintColor" : null,
       "matchTerminalBackground" : false
     },

     // socketPassword is deliberately absent. This file is version-controlled,
     // and a key present here is file-managed, so cmux would write the secret
     // into the repository. Omitting it makes cmux fall back to the value held
     // in its own Settings storage. Do not add it back.
     "automation" : {
       "ripgrepBinaryPath" : "",
       "suppressSubagentNotifications" : true,
       "ampIntegration" : true,
       "cursorIntegration" : true,
       "socketControlMode" : "cmuxOnly",
       "geminiIntegration" : true,
       "kiroNotificationLevel" : "standard",
       "portBase" : 9100,
       "portRange" : 10,
       "claudeCodeIntegration" : true,
       "kiroIntegration" : true,
       "claudeBinaryPath" : ""
     },

     "browser" : {
       "urlsToAlwaysOpenExternally" : [

       ],
       "interceptTerminalOpenCommandInCmuxBrowser" : true,
       "defaultSearchEngine" : "google",
       "insecureHttpHostsAllowedInEmbeddedBrowser" : [
