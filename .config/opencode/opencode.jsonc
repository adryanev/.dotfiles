{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "x-api-key": "{env:CONTEXT7_API_KEY}"
      }
    },
    "codebase-memory-mcp": {
      "type": "local",
      "command": ["/Users/adryanev/.local/bin/codebase-memory-mcp"]
    },
    "serena": {
      "type": "local",
      // Absolute path: ~/.local/bin is on PATH only for login shells, so a
      // bare "serena" fails when OpenCode is launched from a GUI application.
      "command": ["/Users/adryanev/.local/bin/serena", "start-mcp-server", "--context=ide", "--project-from-cwd"]
    },
    "tablepro": {
      "type": "local",
      "command": ["/Applications/TablePro.app/Contents/MacOS/tablepro-mcp"]
    }
  }
}
