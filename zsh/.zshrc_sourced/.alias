# ═══════════════════════════════════════════════════════════════
# ALIASES
# ═══════════════════════════════════════════════════════════════

# Navigation
#alias cd="z"                    # Use zoxide for smart cd
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."

# List commands (eza is modern ls replacement)
if command -v eza &> /dev/null; then
  alias ls="eza --icons --group-directories-first"
  alias ll="eza -l --icons --group-directories-first --git"
  alias la="eza -la --icons --group-directories-first --git"
  alias lt="eza --tree --level=2 --icons"
  alias lta="eza --tree --level=2 --icons -a"
else
  alias ls="ls --color=auto"
  alias ll="ls -lh"
  alias la="ls -lAh"
fi

# Git shortcuts (complement oh-my-zsh git plugin)
alias g="git"
alias gs="git status"
alias ga="git add"
alias gc="git commit"
alias gp="git push"
alias gl="git pull"
alias gd="git diff"
alias gco="git checkout"
alias gb="git branch"
alias glog="git log --graph --oneline --decorate"

# Tmux
alias ta="tmux attach -t"
alias tl="tmux list-sessions"
alias tn="tmux new -s"
alias tk="tmux kill-session -t"

# Editor
alias vim="nvim"
alias vi="nvim"
alias v="nvim"

# Development
alias ports="lsof -i -P -n | grep LISTEN"  # Show listening ports
alias myip="curl ifconfig.me"              # Get public IP

# Docker (if used)
alias dc="docker compose"
alias dcu="docker compose up"
alias dcd="docker compose down"
alias dcl="docker compose logs -f"


# Quick edits
alias zshrc="nvim ~/.zshrc"
alias aliases="nvim ~/.zshrc_sourced/.alias"
alias reload="source ~/.zshrc && echo 'ZSH config reloaded!'"

# System
alias cleanup="brew cleanup && brew autoremove"
alias update="brew update && brew upgrade && brew cleanup"

# Claude
alias claude-dsp="CLAUDE_CONFIG_DIR=~/.claude-dsp claude"
# Serena system prompt override (+s), permissions skipped
alias cs='claude --dangerously-skip-permissions --system-prompt="$(serena prompts print-cc-system-prompt-override)"'
alias cxs='claudex --dangerously-skip-permissions --system-prompt="$(serena prompts print-cc-system-prompt-override)"'
alias cdps='claude-dsp --dangerously-skip-permissions --system-prompt="$(serena prompts print-cc-system-prompt-override)"'

claudex-start() {
  brew services start cliproxyapi
}

claudex-stop() {
  brew services stop cliproxyapi
}

claudex-login() {
  /opt/homebrew/opt/cliproxyapi/bin/cliproxyapi -codex-login "$@"
}

claudex-models() {
  local base_url="${CLAUDEX_BASE_URL:-http://127.0.0.1:8317}"
  local auth_token="${CLAUDEX_AUTH_TOKEN:-sk-claudex-local}"

  curl -fsS \
    -H "Authorization: Bearer ${auth_token}" \
    "${base_url}/v1/models" \
    | jq -r '.data[].id' \
    | sort
}

claudex() {
  local base_url="${CLAUDEX_BASE_URL:-http://127.0.0.1:8317}"
  local auth_token="${CLAUDEX_AUTH_TOKEN:-sk-claudex-local}"
  local model="${CLAUDEX_MODEL:-gpt-5.6-sol}"
  local subagent_model="${CLAUDEX_SUBAGENT_MODEL:-gpt-5.6-terra}"
  local has_model=0
  local arg

  if [[ $# -gt 0 && "$1" != -* ]]; then
    model="$1"
    shift
  fi

  local args=("$@")
  local i=1
  while (( i <= ${#args[@]} )); do
    arg="${args[$i]}"
    if [[ "$arg" == "--model" ]]; then
      has_model=1
      if (( i < ${#args[@]} )); then
        model="${args[$((i + 1))]}"
      fi
      break
    elif [[ "$arg" == --model=* ]]; then
      has_model=1
      model="${arg#--model=}"
      break
    fi
    (( i++ ))
  done

  local model_args=()
  if (( ! has_model )); then
    model_args=(--model "$model")
  fi

  env \
    CLAUDE_CONFIG_DIR="$HOME/.claudex" \
    ANTHROPIC_BASE_URL="$base_url" \
    ANTHROPIC_AUTH_TOKEN="$auth_token" \
    ANTHROPIC_DEFAULT_OPUS_MODEL="$model" \
    ANTHROPIC_DEFAULT_SONNET_MODEL="$model" \
    ANTHROPIC_DEFAULT_HAIKU_MODEL="$model" \
    ANTHROPIC_MODEL="$model" \
    ANTHROPIC_SMALL_FAST_MODEL="$model" \
    CLAUDE_CODE_SUBAGENT_MODEL="$subagent_model" \
    CLAUDE_CODE_ALWAYS_ENABLE_EFFORT=1 \
    CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY=3 \
    CLAUDE_CODE_MAX_CONTEXT_TOKENS=400000 \
    ENABLE_TOOL_SEARCH=false \
    claude "${model_args[@]}" "$@"
}
