# ═══════════════════════════════════════════════════════════════
# DEVELOPMENT ENVIRONMENT
# ═══════════════════════════════════════════════════════════════
# Tool-specific configurations and completions

# ───────────────────────────────────────────────────────────────
# Bun JavaScript runtime
# ───────────────────────────────────────────────────────────────
if [ -s "$HOME/.bun/_bun" ]; then
  source "$HOME/.bun/_bun"  # Bun shell completions
fi

# ───────────────────────────────────────────────────────────────
# Dart/Flutter
# ───────────────────────────────────────────────────────────────
if [[ -f "$HOME/.dart-cli-completion/zsh-config.zsh" ]]; then
  source "$HOME/.dart-cli-completion/zsh-config.zsh"
fi

# ───────────────────────────────────────────────────────────────
# Node.js environment variables
# ───────────────────────────────────────────────────────────────
# Increase Node.js memory limit for large projects
export NODE_OPTIONS="--max-old-space-size=4096"

# ───────────────────────────────────────────────────────────────
# Go environment
# ───────────────────────────────────────────────────────────────
export GO111MODULE=on
# GOPATH/GOROOT are set by asdf golang plugin via set-env.zsh (loaded at end of file)

# ───────────────────────────────────────────────────────────────
# Python/UV environment
# ───────────────────────────────────────────────────────────────
# UV cache directory
export UV_CACHE_DIR="$HOME/.cache/uv"

# ───────────────────────────────────────────────────────────────
# Android development
# ───────────────────────────────────────────────────────────────
export ANDROID_HOME="$HOME/Library/Android/sdk"
export ANDROID_SDK_ROOT="$ANDROID_HOME"

# ───────────────────────────────────────────────────────────────
# Utility functions
# ───────────────────────────────────────────────────────────────

# List installed development tools and their versions
function list-tools() {
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "📦 Development Tools"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  # JavaScript/TypeScript
  echo "Node.js:  $(node -v 2>/dev/null || echo '❌ not installed')"
  echo "npm:      $(npm -v 2>/dev/null || echo '❌ not installed')"
  echo "pnpm:     $(pnpm --version 2>/dev/null || echo '❌ not installed')"
  echo "Bun:      $(bun --version 2>/dev/null || echo '❌ not installed')"

  # Python
  echo "Python:   $(python3 --version 2>/dev/null | cut -d' ' -f2 || echo '❌ not installed')"
  echo "uv:       $(uv --version 2>/dev/null | cut -d' ' -f2 || echo '❌ not installed')"

  # Other languages
  echo "Go:       $(go version 2>/dev/null | cut -d' ' -f3 || echo '❌ not installed')"
  echo "Rust:     $(rustc --version 2>/dev/null | cut -d' ' -f2 || echo '❌ not installed')"
  echo "PHP:      $(php -v 2>/dev/null | head -n1 | cut -d' ' -f2 || echo '❌ not installed')"
  echo "Composer: $(composer --version 2>/dev/null | cut -d' ' -f3 || echo '❌ not installed')"
  echo "Ruby:     $(ruby -v 2>/dev/null | cut -d' ' -f2 || echo '❌ not installed')"
  echo "Java:     $(java -version 2>&1 | head -n1 | cut -d'"' -f2 || echo '❌ not installed')"

  # Mobile
  echo "Flutter:  $(flutter --version 2>/dev/null | head -n1 | cut -d' ' -f2 || echo '❌ not installed')"

  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
}

# Load asdf golang environment (sets GOROOT, GOPATH, GOBIN)
if [[ -f "${ASDF_DATA_DIR:-$HOME/.asdf}/plugins/golang/set-env.zsh" ]]; then
  . "${ASDF_DATA_DIR:-$HOME/.asdf}/plugins/golang/set-env.zsh"
fi

